---
import { services } from '../data/site';
---

<section class="services section" id="services" aria-labelledby="services-title">
  <div class="container">
    <div class="services__grid">
      {
        services.map((service) => (
          <a href={service.href} class="service-card">
            <span class="service-card__icon">
              <img src={service.icon} alt="" width="48" height="48" loading="lazy" />
            </span>
            <span class="service-card__label">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M12.25 7H1.75" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                <path d="M8.75 3.5L12.25 7L8.75 10.5" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              </svg>
              {service.label}
            </span>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .services {
    background: var(--color-secondary);
    padding-block: clamp(2rem, 5vw, 3rem);
  }

  .services__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .service-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    padding: 1.25rem 1rem;
    background: rgba(255, 255, 255, 0.6);
    border-radius: var(--radius);
    text-align: center;
    transition: transform var(--transition), background var(--transition), box-shadow var(--transition);
  }

  .service-card:hover {
    transform: translateY(-4px);
    background: #fff;
    box-shadow: var(--shadow);
  }

  .service-card__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
  }

  .service-card__label {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-primary);
  }

  @media (min-width: 640px) {
    .services__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
</style>
