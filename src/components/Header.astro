---
import Navigation from './Navigation.astro';
---

<header class="header">
  <div class="container header__inner">
    <a href="/" class="header__logo" aria-label="DaisyWoont.nl home">
      <img src="/images/Frame-233.svg" alt="DaisyWoont.nl logo" width="103" height="33" />
    </a>

    <form class="header__search" action="/blog/" method="get" role="search">
      <label for="site-search" class="sr-only">Zoeken</label>
      <svg class="header__search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"/>
        <path d="M20 20L16.5 16.5" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
      <input
        id="site-search"
        type="search"
        name="q"
        placeholder="Waar ben je naar opzoek?"
        autocomplete="off"
      />
    </form>

    <Navigation />
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: #fff;
    border-bottom: 1px solid var(--color-border);
    box-shadow: 0 2px 12px rgba(10, 10, 10, 0.04);
  }

  .header__inner {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding-block: 1rem;
  }

  .header__logo img {
    height: 33px;
    width: auto;
  }

  .header__search {
    flex: 1;
    display: none;
    align-items: center;
    gap: 0.5rem;
    max-width: 320px;
    margin-inline: auto;
    padding: 0.5rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: var(--color-bg-soft);
    transition: border-color var(--transition), box-shadow var(--transition);
  }

  .header__search:focus-within {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(127, 166, 238, 0.2);
  }

  .header__search-icon {
    flex-shrink: 0;
    color: var(--color-muted);
  }

  .header__search input {
    flex: 1;
    border: none;
    background: transparent;
    font-family: inherit;
    font-size: 0.875rem;
    outline: none;
    min-width: 0;
  }

  @media (min-width: 768px) {
    .header__search {
      display: flex;
    }
  }

  @media (min-width: 1024px) {
    .header__inner {
      gap: 2rem;
    }
  }
</style>
