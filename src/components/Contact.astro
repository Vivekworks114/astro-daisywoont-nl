---
interface Props {
  fullPage?: boolean;
}

const { fullPage = false } = Astro.props;
---

<section class:list={['contact section', fullPage && 'contact--page']} id="contact" aria-labelledby="contact-title">
  <div class="container contact__grid">
    <div class="contact__info">
      <h2 id="contact-title">{fullPage ? 'Contact' : 'Neem contact op'}</h2>
      <p>
        Neem contact op met DaisyWoont.nl voor al jouw vragen. Wil je een samenwerking met ons
        aangaan? We horen graag van je!
      </p>

      <div class="contact__details">
        <div class="contact__detail">
          <strong>E-mail</strong>
          <a href="mailto:info@daisywoont.nl">info@daisywoont.nl</a>
        </div>
        <div class="contact__detail">
          <strong>Website</strong>
          <a href="https://daisywoont.nl">daisywoont.nl</a>
        </div>
      </div>
    </div>

    <div class="contact__form-wrap">
      {fullPage && (
        <div class="contact__image">
          <img
            src="/images/waist-up-shot-positive-attractive-young-european-woman-employee-student-wearing-red-lipstick-oval-glasses-smiling-confidently-keeping-arms-folded-posing-isolated-2.png"
            alt="DaisyWoont.nl contactpersoon"
            loading="lazy"
          />
        </div>
      )}

      <form class="contact__form" action="#" method="post">
        <div class="contact__field">
          <label for="name">Naam</label>
          <input type="text" id="name" name="name" placeholder="Je naam" required />
        </div>
        <div class="contact__field">
          <label for="email">E-mail</label>
          <input type="email" id="email" name="email" placeholder="E-mail" required />
        </div>
        <div class="contact__field">
          <label for="message">Bericht</label>
          <textarea id="message" name="message" rows="5" placeholder="Je bericht" required></textarea>
        </div>
        <button type="submit" class="btn btn-primary">Versturen</button>
      </form>
    </div>
  </div>
</section>

<style>
  .contact {
    background: var(--color-bg-soft);
  }

  .contact--page {
    padding-block: clamp(3rem, 6vw, 4rem);
  }

  .contact__grid {
    display: grid;
    gap: 2.5rem;
    align-items: start;
  }

  .contact__info p {
    color: var(--color-muted);
    max-width: 480px;
  }

  .contact__details {
    display: grid;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .contact__detail strong {
    display: block;
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-muted);
    margin-bottom: 0.25rem;
  }

  .contact__detail a {
    color: var(--color-accent);
    font-weight: 500;
    transition: color var(--transition);
  }

  .contact__detail a:hover {
    color: var(--color-primary);
  }

  .contact__form-wrap {
    display: grid;
    gap: 2rem;
  }

  .contact__image img {
    max-width: 280px;
    margin-inline: auto;
  }

  .contact__form {
    display: grid;
    gap: 1rem;
    padding: 1.5rem;
    background: #fff;
    border-radius: var(--radius);
    box-shadow: var(--shadow);
  }

  .contact__field label {
    display: block;
    font-size: 0.875rem;
    font-weight: 500;
    margin-bottom: 0.375rem;
  }

  .contact__field input,
  .contact__field textarea {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    font-family: inherit;
    font-size: 0.9375rem;
    transition: border-color var(--transition), box-shadow var(--transition);
  }

  .contact__field input:focus,
  .contact__field textarea:focus {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(127, 166, 238, 0.2);
  }

  .contact__field textarea {
    resize: vertical;
    min-height: 120px;
  }

  @media (min-width: 768px) {
    .contact__grid {
      grid-template-columns: 1fr 1fr;
    }

    .contact--page .contact__form-wrap {
      grid-template-columns: auto 1fr;
      align-items: start;
    }
  }
</style>
