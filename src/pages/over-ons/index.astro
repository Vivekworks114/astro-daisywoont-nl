---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import pagesFromWp from '../../data/pages-from-wp.json';

const page = pagesFromWp.find((p) => p.slug === 'over-ons');
if (!page) throw new Error('Over ons page not found');
---

<Layout
  title="Over ons | DaisyWoont.nl"
  description="Leer het team van DaisyWoont.nl kennen. Wij delen woontips, productreviews en inspiratie voor jouw interieur."
>
  <Header />
  <main id="main" class="page-content section">
    <div class="container wp-content" set:html={page.content} />
  </main>
  <Footer />
</Layout>

<style>
  .page-content .container {
    max-width: 800px;
  }

  .wp-content :global(h1) {
    margin-bottom: 1.5rem;
  }

  .wp-content :global(p) {
    line-height: 1.75;
    margin-bottom: 1rem;
    color: var(--color-muted);
  }

  .wp-content :global(img) {
    border-radius: var(--radius);
    margin-block: 2rem;
    max-width: 100%;
    height: auto;
  }

  .wp-content :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
  }
</style>
